// --- NTP TIME SYNC ---

void syncTimeFromNTP() {
  tft.fillRect(0, 100, 320, 140, ILI9341_BLACK);
  tft.setCursor(10, 110);
  tft.setTextColor(ILI9341_YELLOW);
  tft.println("Syncing Time...");
  
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  struct tm timeinfo;
  if (getLocalTime(&timeinfo, 10000)) {
    Serial.println("NTP Time synchronized!");
    rtc.adjust(DateTime(timeinfo.tm_year + 1900, timeinfo.tm_mon + 1, timeinfo.tm_mday, timeinfo.tm_hour, timeinfo.tm_min, timeinfo.tm_sec));
    tft.setTextColor(ILI9341_GREEN);
    tft.println("Time Synced!");
  } else {
    Serial.println("Failed to obtain time from NTP");
    tft.setTextColor(ILI9341_RED);
    tft.println("NTP Sync Failed");
  }
  delay(1000);
}

void setup() {
  globalSecureClient.setInsecure();
  Serial.begin(115200);
  Serial.println("\n--- ATTENDANCE SYSTEM BOOT ---");

  pinMode(15, OUTPUT);
  digitalWrite(15, HIGH); // deselect TFT CS so it doesn't interfere with RC522 on shared SPI bus

  tft.begin();
  tft.setRotation(1);
  tft.fillScreen(ILI9341_BLACK);
  tft.setTextColor(ILI9341_WHITE);
  tft.setTextFont(2);
  tft.setCursor(10, 10);
  tft.println("Booting...");

  SPI.begin();
  
  tft.print("RTC: ");
  Serial.print("RTC: ");
  if (!rtc.begin()) {
    Serial.println("FAIL (Couldn't find RTC)");
    tft.setTextColor(ILI9341_RED);
    tft.println("FAIL");
  } else {
    Serial.println("OK");
    tft.setTextColor(ILI9341_GREEN);
    tft.println("OK");
  }
  tft.setTextColor(ILI9341_WHITE);

  mySerial.begin(57600, SERIAL_8N1, 16, 17);
  delay(500);
  finger.begin(57600);
  
  tft.print("Fingerprint: ");
  Serial.print("Fingerprint: ");
  if (finger.verifyPassword()) {
    Serial.println("OK (Found sensor)");
    tft.setTextColor(ILI9341_GREEN);
    tft.println("OK");
  } else {
    Serial.println("FAIL (Did not find sensor)");
    tft.setTextColor(ILI9341_RED);
    tft.println("FAIL");
  }
  tft.setTextColor(ILI9341_WHITE);

  tft.print("RFID: ");
  Serial.print("RFID: ");
  rfid.PCD_Init();
  byte v = rfid.PCD_ReadRegister(rfid.VersionReg);
  if (v == 0x00 || v == 0xFF) {
    Serial.println("FAIL (Check wiring)");
    tft.setTextColor(ILI9341_RED);
    tft.println("FAIL");
  } else {
    Serial.println("OK");
    tft.setTextColor(ILI9341_GREEN);
    tft.println("OK");
  }
  tft.setTextColor(ILI9341_WHITE);
  
  delay(1500); // Give user a moment to read the statuses

  // WiFi connect
  tft.fillScreen(ILI9341_BLACK);
  tft.setCursor(10, 10);
  tft.println("Connecting WiFi...");
  
  WiFiManager wm;
  
  // Custom callback to show instructions when AP spins up
  wm.setAPCallback([](WiFiManager *myWiFiManager) {
    tft.fillScreen(ILI9341_BLACK);
    tft.setCursor(10, 10);
    tft.setTextColor(ILI9341_RED);
    tft.println("NO WIFI FOUND!");
    tft.setTextColor(ILI9341_YELLOW);
    tft.println("");
    tft.println("Please take out phone &");
    tft.println("connect to Wi-Fi:");
    tft.setTextColor(ILI9341_CYAN);
    tft.println("Moon_Setup");
    tft.setTextColor(ILI9341_WHITE);
    tft.println("");
    tft.println("Then sign in to network!");
  });

  bool res = wm.autoConnect("Moon_Setup", "admin123");

  tft.fillScreen(ILI9341_BLACK);
  tft.setCursor(10, 10);

  if (res) {
    Serial.println("\nWiFi Connected! IP: " + WiFi.localIP().toString());
    tft.setTextColor(ILI9341_GREEN);
    tft.println("WiFi Connected!");
    
    // Sync Time
    syncTimeFromNTP();
    
    // Perform Sync
    tft.fillRect(0, 100, 320, 140, ILI9341_BLACK);
    tft.setCursor(10, 110);
    tft.setTextColor(ILI9341_YELLOW);
    tft.println("Syncing Fingerprints...");
    syncFingerprints();
  } else {
    Serial.println("\nWiFi FAILED");
    tft.setTextColor(ILI9341_RED);
    tft.println("WiFi FAILED");
  }

  resetScreen();
  Serial.println("--- READY ---");
  
  // Initialize Offline Queue
  logQueue = xQueueCreate(50, sizeof(LogRecord));
  
  // Spawn Network Task on Core 0
  xTaskCreatePinnedToCore(
    networkTaskCode,
    "NetworkTask",
    10000,
    NULL,
    1,
    &networkTaskHandle,
    0
  );
}

void resetScreen() {
  tft.fillScreen(ILI9341_BLACK);
  
  // Top Left: Moon Attendance (Smaller font to prevent overlap)
  tft.setTextColor(ILI9341_WHITE, ILI9341_BLACK);
  tft.setTextDatum(TL_DATUM);
  tft.drawString("Moon Attendance", 10, 15, 2);

  // Left Side: 3x3 Dashed Scan Placeholder
  tft.setSwapBytes(true);
  tft.pushImage(48, 98, 64, 64, icon_scan);

  // Bottom Center: Professional scanning prompt
  tft.setTextColor(ILI9341_CYAN, ILI9341_BLACK);
  tft.setTextDatum(MC_DATUM);
  tft.drawString("SCAN FINGER / RFID CARD", 160, 220, 2);

  // Force clock and Wi-Fi to redraw in loop()
  lastMinute = -1;
  lastWifiStatus = !(WiFi.status() == WL_CONNECTED);
}

void networkTaskCode(void * pvParameters) {
  while (true) {
    if (WiFi.status() == WL_CONNECTED) {
      // 1. Process Offline Queue
      LogRecord log;
      if (xQueueReceive(logQueue, &log, 0) == pdPASS) {
        HTTPClient http;
        http.begin(globalSecureClient, serverUrl);
        http.addHeader("Connection", "close");
        http.addHeader("x-api-key", API_KEY);
        http.addHeader("Content-Type", "application/json");
        
        JsonDocument doc;
        doc["identifier"] = String(log.uid);
        doc["method"] = String(log.method);
        doc["timestamp"] = String(log.timestamp);
        
        String requestBody;
        serializeJson(doc, requestBody);
        
        int httpCode = http.POST(requestBody);
        
        if (httpCode == 200 || httpCode == 201) {
          Serial.println("Successfully synced log to server!");
        } else {
          Serial.print("Sync Failed! HTTP Code: ");
          Serial.println(httpCode);
          if (httpCode > 0) {
            Serial.println("Response: " + http.getString());
          }
          // Sync Failed, requeue it at the front
          xQueueSendToFront(logQueue, &log, 0);
          vTaskDelay(2000 / portTICK_PERIOD_MS); // wait before retry
        }
        http.end();
      }
      
      // 2. Poll server for mode (every 2 seconds)
      static unsigned long lastPoll = 0;
      if (millis() - lastPoll > 2000) {
        lastPoll = millis();
        HTTPClient http;
        String statusUrl = String(hardwareUrl) + "/status";
        http.begin(globalSecureClient, statusUrl);
        http.addHeader("Connection", "close");
        http.addHeader("x-api-key", API_KEY);
        int httpCode = http.GET();
        if (httpCode == 200) {
          String payload = http.getString();
          JsonDocument doc;
          DeserializationError error = deserializeJson(doc, payload);
          if (!error) {
            String newMode = doc["mode"].as<String>();
            if (newMode != currentMode) {
              currentMode = newMode;
              modeChanged = true;
              Serial.println("Mode changed to: " + currentMode);
            }
          }
        } else {
          Serial.print("Polling Server Failed. HTTP Code: ");
          Serial.println(httpCode);
          if (httpCode < 0) {
             Serial.printf("Error details: %s\n", http.errorToString(httpCode).c_str());
          }
        }
        http.end();
        globalSecureClient.stop();
      }
    }
    vTaskDelay(50 / portTICK_PERIOD_MS); // Yield to other tasks
  }
}

void loop() {
  if (currentMode == "attendance") {
    if (modeChanged) {
      resetScreen();
      modeChanged = false;
    }
    
    // Dynamic UI Updates
    DateTime now = rtc.now();
    bool currentWifi = (WiFi.status() == WL_CONNECTED);
    
    if (now.minute() != lastMinute) {
      char timeStr[10];
      sprintf(timeStr, "%02d:%02d", now.hour(), now.minute());
      tft.setTextColor(ILI9341_WHITE, ILI9341_BLACK);
      tft.setTextDatum(MC_DATUM);
      tft.drawString(timeStr, 220, 130, 7);
      lastMinute = now.minute();
    }
    
    if (currentWifi != lastWifiStatus) {
      tft.setSwapBytes(true);
      if (currentWifi) {
        tft.setTextColor(ILI9341_GREEN, ILI9341_BLACK);
        tft.setTextDatum(TR_DATUM);
        tft.drawString("connected ", 275, 15, 2);
        tft.pushImage(280, 5, 32, 32, icon_wifi_on);
      } else {
        tft.setTextColor(ILI9341_RED, ILI9341_BLACK);
        tft.setTextDatum(TR_DATUM);
        tft.drawString("offline   ", 275, 15, 2);
        tft.pushImage(280, 5, 32, 32, icon_wifi_off);
      }
      lastWifiStatus = currentWifi;
    }

    checkFingerprint();
    checkRFID();
  } else if (currentMode == "enroll_fingerprint") {
    if (modeChanged) {
      tft.fillScreen(ILI9341_BLACK);
      tft.fillRoundRect(10, 10, 300, 45, 8, tft.color565(80, 80, 30));
      tft.setTextColor(ILI9341_WHITE, tft.color565(80, 80, 30));
      tft.setTextDatum(MC_DATUM);
      tft.drawString("ENROLL FINGER", 160, 32, 4);

      tft.setTextColor(ILI9341_YELLOW, ILI9341_BLACK);
      tft.drawString("Waiting for server...", 160, 120, 4);
      modeChanged = false;
    }
    enrollFingerprint();
  } else if (currentMode == "enroll_rfid") {
    if (modeChanged) {
      tft.fillScreen(ILI9341_BLACK);
      tft.fillRoundRect(10, 10, 300, 45, 8, tft.color565(80, 80, 30));
      tft.setTextColor(ILI9341_WHITE, tft.color565(80, 80, 30));
      tft.setTextDatum(MC_DATUM);
      tft.drawString("ENROLL RFID", 160, 32, 4);

      tft.setTextColor(ILI9341_YELLOW, ILI9341_BLACK);
      tft.drawString("Tap New Card...", 160, 120, 4);
      modeChanged = false;
    }
    enrollRFID();
  } else if (currentMode == "sync") {
    tft.fillScreen(ILI9341_BLACK);
    tft.fillRoundRect(10, 10, 300, 45, 8, tft.color565(80, 80, 30));
    tft.setTextColor(ILI9341_WHITE, tft.color565(80, 80, 30));
    tft.setTextDatum(MC_DATUM);
    tft.drawString("CLOUD SYNC", 160, 32, 4);

    tft.setTextColor(ILI9341_YELLOW, ILI9341_BLACK);
    tft.drawString("Fetching Employees...", 160, 120, 4);
    syncFingerprints();
    
    // Reset server back to attendance mode (sync is one-shot)
    resetServer();
    
    currentMode = "attendance";
    resetScreen();
  }
  
  delay(50);
}

void checkFingerprint() {
  uint8_t p = finger.getImage();
  if (p != FINGERPRINT_OK) return;

  p = finger.image2Tz();
  if (p != FINGERPRINT_OK) return;

  p = finger.fingerSearch();
  if (p == FINGERPRINT_OK) {
    int id = finger.fingerID;
    Serial.print("Found ID #"); Serial.print(id);
    Serial.print(" with confidence of "); Serial.println(finger.confidence);

    tft.fillScreen(ILI9341_BLACK);
    
    // Draw Top Header Bar (Green)
    tft.fillRoundRect(10, 10, 300, 45, 8, tft.color565(30, 100, 30));
    tft.setTextColor(ILI9341_WHITE, tft.color565(30, 100, 30));
    tft.setTextDatum(MC_DATUM);
    tft.drawString("ACCESS GRANTED", 160, 32, 4);

    tft.setSwapBytes(true);
    tft.pushImage(128, 70, 64, 64, icon_success);

    tft.setTextColor(ILI9341_GREEN, ILI9341_BLACK);
    tft.drawString("SUCCESS!", 160, 155, 4);
    
    tft.setTextColor(ILI9341_WHITE, ILI9341_BLACK);
    tft.drawString("ID: " + String(id), 160, 195, 4);
    
    // Add to Offline Queue
    LogRecord newLog;
    strcpy(newLog.uid, String(id).c_str());
    strcpy(newLog.method, "fingerprint");
    strcpy(newLog.timestamp, rtc.now().timestamp().c_str());
    xQueueSend(logQueue, &newLog, 0);

    delay(1500);
    resetScreen();
  } else {
    tft.fillScreen(ILI9341_BLACK);
    
    // Draw Top Header Bar (Red)
    tft.fillRoundRect(10, 10, 300, 45, 8, tft.color565(120, 30, 30));
    tft.setTextColor(ILI9341_WHITE, tft.color565(120, 30, 30));
    tft.setTextDatum(MC_DATUM);
    tft.drawString("ACCESS DENIED", 160, 32, 4);

    tft.setSwapBytes(true);
    tft.pushImage(128, 70, 64, 64, icon_error);

    tft.setTextColor(ILI9341_RED, ILI9341_BLACK);
    tft.drawString("TRY AGAIN!", 160, 155, 4);
    
    delay(1500);
    resetScreen();
  }
}

void checkRFID() {
  if (!rfid.PICC_IsNewCardPresent() || !rfid.PICC_ReadCardSerial()) return;

  String uidStr = "";
  for (byte i = 0; i < rfid.uid.size; i++) {
    if (rfid.uid.uidByte[i] < 0x10) uidStr += "0";
    uidStr += String(rfid.uid.uidByte[i], HEX);
    if (i < rfid.uid.size - 1) uidStr += " ";
  }
  uidStr.toUpperCase();

  Serial.println("Card UID: " + uidStr);
  
  tft.fillScreen(ILI9341_BLACK);
  
  // Draw Top Header Bar (Green)
  tft.fillRoundRect(10, 10, 300, 45, 8, tft.color565(30, 100, 30));
  tft.setTextColor(ILI9341_WHITE, tft.color565(30, 100, 30));
  tft.setTextDatum(MC_DATUM);
  tft.drawString("ACCESS GRANTED", 160, 32, 4);

  tft.setSwapBytes(true);
  tft.pushImage(128, 70, 64, 64, icon_success);

  tft.setTextColor(ILI9341_GREEN, ILI9341_BLACK);
  tft.drawString("RFID SAVED!", 160, 155, 4);
  
  // Add to Offline Queue
  LogRecord newLog;
  strcpy(newLog.uid, uidStr.c_str());
  strcpy(newLog.method, "rfid");
  strcpy(newLog.timestamp, rtc.now().timestamp().c_str());
  xQueueSend(logQueue, &newLog, 0);
  
  delay(1500);
  resetScreen();

  rfid.PICC_HaltA();
}

