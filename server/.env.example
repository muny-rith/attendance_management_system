# =============================================
# SERVER ENVIRONMENT VARIABLES — .env.example
# Copy this to .env and fill in real values
# =============================================

# PostgreSQL connection
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=attendance
DB_PASSWORD=your_database_password_here
DB_PORT=5432

# Express server port
PORT=3000

# API key — used by ESP32 hardware AND the React frontend
# Change this to a long random string in production!
API_KEY=moon_attendance_secret_2026

# URL of the deployed frontend (for CORS restriction)
# Change this to your real frontend URL in production, e.g. https://attendance.yourdomain.com
CLIENT_URL=http://localhost:5173
